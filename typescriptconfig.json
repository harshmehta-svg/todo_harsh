{
  "compilerOptions": {
    "baseUrl": "./",
    "outDir": "./src/__tmp/",
    "sourceMap": true,
    "noImplicitAny": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "target": "es2015",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"],
  "resolveJsonModule": true,
  "jsx": "react-jsx"
}