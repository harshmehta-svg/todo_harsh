    "lint": "eslint \"src/**/*.ts\" && eslint \"src/**/*.tsx\" && eslint \"src/**/*.{js,jsx}\"",
    "format": "prettier --write \"src/**/*.ts\" && prettier --write \"src/**/*.tsx\" && prettier --write \"src/**/*.{js,jsx}\""
