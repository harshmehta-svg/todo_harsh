{
  "name": "todo-app",
  "version": "1.0.0",
  "description": "A simple Todo List application built with front-end technologies.",
  "main": "src/index.js", // Update main field to point to React entry point
  "scripts":{
    "start": "live-server",
    {
      "build": "tsc --outDir build ",
      "build:react": "webpack --mode production src/index.js --output-filename main.js "
    },{
      "test": "jest",
    },
    {
      "clean": "rm -rf build && touch build",
      "test:coverage": "jest --coverage ",
      "clean-react": "rm -rf build/* && npm run build:react ",
      "test-react": "jest src"
    }
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/node": "^16.11.3",
    "bcrypt": "^5.2.1",
    "typescript": "^4.7.4",
    "webpack": "^5.74.0",
    "webpack-cli": "^4.9.2",
    "webpack-dev-server": "^4.0.0"
  },
  "devDependencies": {
    "@types/jest": "^28.1.6",
    "@types/jquery": "^3.6.2",
    "@types/live-server": "^1.2.7",
    "glob": "^7.2.7",
    "jest": "^28.1.3",
    "live-server": "^1.2.1",
    "ts-jest": "^28.0.5",
    "ts-loader": "^9.3.0",
    "typescript": "^4.7.4",
    "webpack-merge": "^11.2.0"
  },
