{
  "name": "todo-app",
  "version": "1.0.0",
  "description": "A simple Todo List application built with front-end technologies.",
  "main": "index.js", // Changed main field to a valid entry point (in this case, a JavaScript file)
  "scripts": {
    "start": "live-server",
    "build": "tsc --outDir build",
    "test": "jest",
    "clean": "rm -rf build && touch build",
    "login": "node server/login.js", // Added new script to start login server
    "remove-duplicates": "glob \"*.js\" && glob \"*.css\" && glob \"*.html\" && rm -rf styles.css && rm -rf index.html && rm -rf index.css && rm -rf app.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/node": "^16.11.3",
    "bcrypt": "^5.2.1",
    "typescript": "^4.7.4",
    "express": "^4.17.1" // Added express dependency for server
  },
  "devDependencies": {
    "@types/jest": "^28.1.6",
    "@types/jquery": "^3.6.2",
    "@types/live-server": "^1.2.7",
    "jest": "^28.1.3",
    "live-server": "^1.2.1",
    "glob": "^7.2.7" // Added glob dependency to remove unnecessary files
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "bugs": {
    "url": ""
  }
