  "description": "A simple Home design application.",
  "main": "index.js", // Changed main field to a valid entry point (in this case, a JavaScript file)
  "scripts": {
    "start": "live-server",
    "build": "tsc --outDir build",
    "test": "jest",
    "clean": "rm -rf build && touch build",
    "create-design": "npm run clean && live-server design.html && tsc --outDir design",
    "remove-duplicates": "glob \"*.js\" && glob \"*.css\" && glob \"*.html\" && rm -rf styles.css && rm -rf index.html && rm -rf index.css && rm -rf app.js"
  },
